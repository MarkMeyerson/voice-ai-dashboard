# ============================================================
#  VoiceDesk — environment variables
#  Copy this file to .env.local and fill in your own values.
#  NEVER commit .env.local. Everything here is a placeholder.
# ============================================================

# --- Supabase (Project Settings > API) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, bypasses RLS (webhooks/admin). Keep secret.

# --- Stripe (Developers > API keys; start in TEST mode) --------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...                   # from the webhook endpoint you create in Stripe
STRIPE_METER_ID=mtr_...                           # the usage Meter you create (see README)
STRIPE_METER_EVENT=voicedesk_call_minutes         # the Meter's event_name

# --- Retell AI (Dashboard > API keys) --------------------------------------
RETELL_API_KEY=key_...                            # default key; pods can override with their own
RETELL_WEBHOOK_SECRET=                            # optional

# --- Resend (transactional email) ------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=VoiceDesk <noreply@yourdomain.com>   # use a Resend-verified domain in production

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000          # set to your deployed URL in production
